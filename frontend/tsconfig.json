// frontend/tsconfig.json
{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",  // <-- This setting requires @types/react

    /* Linting */
    "strict": true,

    /* Type Definitions to load */
    "types": ["vite/client", "node"]
  },
  "include": ["src", "playwright.config.ts", "vite.config.ts", "tests"],
  "references": [{ "path": "./tsconfig.node.json" }]
}