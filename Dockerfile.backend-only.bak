# --- Final Stage ---
# This stage builds the final, lightweight production image
FROM python:3.11-slim

# Create a non-root user for security
RUN addgroup --system app && adduser --system --group app

# Set the working directory
WORKDIR /home/app

# Copy the installed dependencies from the builder stage
COPY --from=builder /usr/src/app/wheels /wheels
COPY --from=builder /usr/src/app/requirements.txt .
RUN pip install --no-cache /wheels/*

# Install psql for database shell access
RUN apt-get update && apt-get install -y postgresql-client

# Copy the application code
COPY . .

# Create the staticfiles directory with correct permissions
RUN mkdir -p /home/app/staticfiles && chown -R app:app /home/app/staticfiles

# Change ownership of the files to the non-root user
RUN chown -R app:app /home/app

# Switch to the non-root user
USER app

# Expose the port
EXPOSE 8000

# Run the application with Gunicorn
CMD ["gunicorn", "backend.wsgi:application", "--bind", "0.0.0.0:8000"]
